{
  "HttpLogging": {
    "RequestBodyLogLimit": 4096,
    "ResponseBodyLogLimit": 4096
  },
  "Logging": {
    "LogLevel": {
      "SemanticStub.Api": "Debug",
      "SemanticStub.Api.Services.SemanticMatcherService": "Trace"
    }
  },
  "StubSettings": {
    "SemanticMatching": {
      "Enabled": true,
      "Endpoint": "http://localhost:8081",
      "Threshold": 0.85,
      "TimeoutSeconds": 30
    }
  }
}

{
  "HttpLogging": {
    "LoggingFields": "RequestPropertiesAndHeaders, ResponsePropertiesAndHeaders, RequestBody, ResponseBody",
    "RequestBodyLogLimit": 4096,
    "ResponseBodyLogLimit": 4096
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SemanticStub.Application.Services.Semantic.SemanticMatcherService": "Debug"
    }
  },
  "StubSettings": {
    "SemanticMatching": {
      "Enabled": true,
      "Endpoint": "http://localhost:8081"
    }
  }
}
